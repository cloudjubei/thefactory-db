{
  "name": "thefactory-db",
  "version": "1.0.2",
  "description": "Local-first PostgreSQL toolkit with hybrid text (tsvector) + vector (pgvector) search, Docker-managed ephemeral/persistent databases, and a TypeScript API for documents and entities.",
  "license": "MIT",
  "author": "Kamil Chmurzynski <cloudjubei@gmail.com>",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "docs/",
    "types/",
    "scripts/",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage --coverage.reportOnFailure",
    "test:e2e": "cross-env RUN_E2E=1 DATABASE_URL=postgresql://user:password@localhost:65432/thefactory-db vitest run tests/e2e --no-file-parallelism",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "pack": "npm run clean && npm run build && npm pack --json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dockerode": "^4.0.9",
    "get-port": "^7.1.0",
    "js-tiktoken": "^1.0.21",
    "pg": "^8.16.3",
    "testcontainers": "^11.8.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.45",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "prettier": "^3.6.2",
    "typescript": "^5.5.4",
    "v8": "^0.1.0",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudjubei/thefactory-db.git"
  },
  "bugs": {
    "url": "https://github.com/cloudjubei/thefactory-db/issues"
  },
  "homepage": "https://github.com/cloudjubei/thefactory-db#readme",
  "keywords": [
    "postgres",
    "postgresql",
    "pg",
    "pgvector",
    "vector",
    "vector-search",
    "hybrid-search",
    "fts",
    "full-text-search",
    "tsvector",
    "embeddings",
    "similarity-search",
    "typescript",
    "esm",
    "docker",
    "testcontainers",
    "database",
    "documents",
    "search",
    "thefactory"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
